---
import ThemeToggle from "./ThemeToggle.astro";

const repoUrl = "https://github.com/owner/refscope";

const links = [
  { href: "#what-you-get", label: "What you get" },
  { href: "#demo",         label: "Demo" },
  { href: "#security",     label: "Security" },
  { href: "#quickstart",   label: "Quickstart" },
  { href: "https://github.com/owner/refscope/blob/main/docs/spec-v0.md", label: "Spec", external: true },
];
---
<header class="rs-nav-wrap">
  <nav class="rs-nav rs-container" aria-label="Primary">
    <a href="#" class="rs-brand" aria-label="Refscope home">
      {/* Concentric reticle mark — visual-direction.md §6 option B */}
      <svg class="rs-brand__mark" viewBox="0 0 20 20" width="20" height="20" aria-hidden="true">
        <circle cx="10" cy="10" r="8"   fill="none" stroke="currentColor" stroke-width="1" opacity="0.7" />
        <circle cx="10" cy="10" r="4.5" fill="none" stroke="currentColor" stroke-width="1" opacity="0.9" />
        <line x1="2" y1="10" x2="6" y2="10" stroke="currentColor" stroke-width="1" />
        <line x1="14" y1="10" x2="18" y2="10" stroke="currentColor" stroke-width="1" />
        <circle cx="10" cy="10" r="0.9" fill="currentColor" />
      </svg>
      <span class="rs-brand__word">Refscope</span>
    </a>

    <ul class="rs-nav__links">
      {links.map((l) => (
        <li>
          <a href={l.href} {...(l.external ? { rel: "noreferrer noopener", target: "_blank" } : {})}>{l.label}</a>
        </li>
      ))}
    </ul>

    <div class="rs-nav__controls">
      <ThemeToggle />
      <a class="btn btn-primary rs-nav__cta" href={repoUrl} rel="noreferrer noopener" target="_blank">
        <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        <span>View on GitHub</span>
      </a>
    </div>
  </nav>
</header>

<style>
  .rs-nav-wrap {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: color-mix(in oklab, var(--rs-bg-base) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--rs-border-subtle);
  }
  .rs-nav {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--spacing-4);
    height: 56px;
  }
  .rs-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    font-weight: var(--font-weight-medium);
    color: var(--rs-fg-base);
  }
  .rs-brand__mark { color: var(--color-accent-500); }
  .rs-brand__word { letter-spacing: -0.005em; }

  .rs-nav__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: none;
    gap: var(--spacing-4);
    justify-content: center;
    font-size: var(--text-sm);
    color: var(--rs-fg-subtle);
  }
  @media (min-width: 900px) {
    .rs-nav__links { display: inline-flex; }
  }
  .rs-nav__links a:hover { color: var(--rs-fg-base); }

  .rs-nav__controls {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
  }
  .rs-nav__cta { height: 32px; padding-block: 0; }
  @media (max-width: 480px) {
    .rs-nav__cta span { display: none; }
  }
</style>
