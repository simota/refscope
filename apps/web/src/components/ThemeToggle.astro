---
/**
 * Theme toggle.
 * Cycles system → light → dark → system.
 * Reads/writes the same `refscope-theme` key as the theme stub in Base.astro.
 *
 * The button always shows the *resolved* glyph; the aria-pressed state
 * reflects whether the user has overridden the system preference.
 */
---
<button
  type="button"
  id="rs-theme-toggle"
  class="rs-theme-toggle"
  aria-label="Theme: system. Click to change."
  aria-pressed="false"
  data-pref="system"
  data-resolved="light"
>
  <span class="rs-theme-toggle__icon" aria-hidden="true">
    {/* Sun (light) and moon (dark) inline SVGs; CSS swaps via [data-resolved] */}
    <svg class="rs-theme-toggle__sun" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <circle cx="8" cy="8" r="3" />
      <path d="M8 1.5v1.5M8 13v1.5M1.5 8h1.5M13 8h1.5M3.3 3.3l1.05 1.05M11.65 11.65l1.05 1.05M3.3 12.7l1.05-1.05M11.65 4.35l1.05-1.05" />
    </svg>
    <svg class="rs-theme-toggle__moon" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M13.5 9.8a5.5 5.5 0 1 1-7.3-7.3 5.5 5.5 0 0 0 7.3 7.3z" />
    </svg>
    <svg class="rs-theme-toggle__system" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="3" width="12" height="8" rx="1.5" />
      <path d="M5.5 13.5h5M8 11v2.5" />
    </svg>
  </span>
  <span class="rs-theme-toggle__label" id="rs-theme-toggle-label">System</span>
</button>

<style>
  .rs-theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    height: 32px;
    padding-inline: var(--spacing-2);
    border: 1px solid var(--rs-border-base);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--rs-fg-base);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
  .rs-theme-toggle:hover {
    background: var(--rs-surface-hover);
  }
  .rs-theme-toggle__icon {
    display: inline-flex;
    width: 16px;
    height: 16px;
    position: relative;
  }
  .rs-theme-toggle__icon svg {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  .rs-theme-toggle[data-pref="system"] .rs-theme-toggle__system { opacity: 1; }
  .rs-theme-toggle[data-pref="light"]  .rs-theme-toggle__sun    { opacity: 1; }
  .rs-theme-toggle[data-pref="dark"]   .rs-theme-toggle__moon   { opacity: 1; }
  @media (max-width: 640px) {
    .rs-theme-toggle__label { display: none; }
  }
</style>

<script>
  /* Theme cycle: system → light → dark → system. Persists in localStorage. */
  (function () {
    const KEY = "refscope-theme";
    const order = ["system", "light", "dark"] as const;
    type Pref = (typeof order)[number];

    const button = document.getElementById("rs-theme-toggle");
    const label = document.getElementById("rs-theme-toggle-label");
    if (!button || !label) return;

    const mql = window.matchMedia("(prefers-color-scheme: dark)");

    function resolve(pref: Pref): "light" | "dark" {
      return pref === "system" ? (mql.matches ? "dark" : "light") : pref;
    }

    function apply(pref: Pref) {
      const resolved = resolve(pref);
      document.documentElement.dataset.theme = resolved;
      document.documentElement.dataset.themePref = pref;
      document.documentElement.classList.toggle("dark", resolved === "dark");
      button!.dataset.pref = pref;
      button!.dataset.resolved = resolved;
      button!.setAttribute("aria-pressed", String(pref !== "system"));
      button!.setAttribute("aria-label", `Theme: ${pref}. Click to change.`);
      label!.textContent = pref.charAt(0).toUpperCase() + pref.slice(1);
    }

    const initial = ((): Pref => {
      const stored = localStorage.getItem(KEY) as Pref | null;
      return stored && (order as readonly string[]).includes(stored) ? stored : "system";
    })();
    apply(initial);

    button.addEventListener("click", () => {
      const current = (button.dataset.pref as Pref) ?? "system";
      const idx = order.indexOf(current);
      const next = order[(idx + 1) % order.length];
      try { localStorage.setItem(KEY, next); } catch { /* ignore */ }
      apply(next);
      button.focus(); // focus stays on the toggle after the swap (lp-structure §6)
    });

    /* React to OS-level changes only while in system mode. */
    mql.addEventListener("change", () => {
      if ((button.dataset.pref as Pref) === "system") apply("system");
    });
  })();
</script>
