---
const basePath = (import.meta.env.BASE_URL ?? "/").replace(/\/$/, "");
const repoUrl = "https://github.com/owner/refscope";
---
<section class="rs-hero" aria-labelledby="hero-headline">
  <div class="rs-container rs-hero__inner">
    <p class="rs-eyebrow">An observatory for your refs.</p>

    <h1 id="hero-headline" class="rs-hero__headline">
      Refs change. Refscope records what changed, and when.
    </h1>

    <p class="rs-hero__sub">
      Refscope is a local, read-only observatory for Git refs and history. It watches one repository
      at a time, records what changes, and separates what was observed from what it means.
    </p>

    <div class="rs-hero__ctas">
      <a class="btn btn-primary" href={repoUrl} rel="noreferrer noopener" target="_blank">
        <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        <span>View on GitHub</span>
      </a>
      <a class="btn btn-ghost" href="#demo">See it in action</a>
    </div>

    <p class="rs-hero__meta">Local-first. Read-only. One command. MIT licensed.</p>

    <figure class="rs-hero__figure">
      {/*
        The hero media is a static PNG (no GIF, no video) per lp-structure §4.
        Generated by the capture script; placeholder until run.
        <picture> selects light/dark by media query AND reduced-motion preference.
      */}
      <picture>
        <source
          media="(prefers-color-scheme: dark)"
          srcset={`${basePath}/media/hero-timeline-dark.png 1x, ${basePath}/media/hero-timeline-dark@2x.png 2x`}
        />
        <img
          src={`${basePath}/media/hero-timeline-light.png`}
          srcset={`${basePath}/media/hero-timeline-light.png 1x, ${basePath}/media/hero-timeline-light@2x.png 2x`}
          width="1600"
          height="1000"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          alt="Refscope mock UI showing a three-pane layout: a sidebar with branch and tag refs and a notice that history was rewritten on main, a commit timeline with seven commits and the most recent commit marked as new, and a collapsed detail panel."
        />
      </picture>
      <figcaption class="rs-hero__caption">
        The mock UI mid-session: sidebar with one rewrite notice, timeline with one new commit, detail panel collapsed.
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .rs-hero {
    padding-block: clamp(48px, 9vw, 96px);
  }
  .rs-hero__headline {
    font-size: clamp(28px, 5.2vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-block: var(--spacing-3) var(--spacing-4);
    max-width: 22ch;
  }
  .rs-hero__sub {
    color: var(--rs-fg-subtle);
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: var(--leading-normal);
    max-width: 64ch;
  }
  .rs-hero__ctas {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    margin-block: var(--spacing-6) var(--spacing-2);
  }
  .rs-hero__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--rs-fg-subtle);
  }
  .rs-hero__figure {
    margin: clamp(32px, 5vw, 56px) 0 0;
    padding: 0;
  }
  .rs-hero__figure picture {
    display: block;
    border: 1px solid var(--rs-border-subtle);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--rs-bg-sunken);
    /* Placeholder aspect to prevent CLS while the image loads
       (and to remain visually stable if the asset is missing in dev). */
    aspect-ratio: 16 / 10;
  }
  .rs-hero__figure img {
    width: 100%;
    height: auto;
    display: block;
  }
  .rs-hero__caption {
    margin-top: var(--spacing-3);
    font-size: var(--text-sm);
    color: var(--rs-fg-subtle);
    max-width: 64ch;
  }
</style>
