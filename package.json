{
  "name": "refscope",
  "version": "0.0.1",
  "description": "An observatory for Git refs and history. Local, read-only, allowlist-scoped.",
  "private": true,
  "license": "MIT",
  "homepage": "https://simota.github.io/refscope/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simota/refscope.git"
  },
  "bugs": {
    "url": "https://github.com/simota/refscope/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.9.0",
  "bin": {
    "refscope": "./apps/cli/bin/refscope.mjs"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @realtime-git-viewer/api dev",
    "build:api": "pnpm --filter @realtime-git-viewer/api build",
    "dev:ui": "pnpm --filter @realtime-git-viewer/ui dev",
    "build:ui": "pnpm --filter @realtime-git-viewer/ui build",
    "dev:web": "pnpm --filter @realtime-git-viewer/web dev",
    "build:web": "pnpm --filter @realtime-git-viewer/web build",
    "preview:web": "pnpm --filter @realtime-git-viewer/web preview",
    "capture:web": "pnpm --filter @realtime-git-viewer/web capture",
    "build:cli": "pnpm --filter refscope build",
    "dev:cli": "pnpm --filter refscope build && node apps/cli/bin/refscope.mjs --repo .",
    "dev": "pnpm dev:ui",
    "build": "pnpm build:api && pnpm build:ui && pnpm build:web",
    "test": "pnpm --filter @realtime-git-viewer/api test",
    "prepare": "node apps/cli/scripts/build.mjs"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.2"
    }
  }
}
