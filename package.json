{
  "name": "realtime-git-viewer",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "dev:api": "pnpm --filter @realtime-git-viewer/api dev",
    "build:api": "pnpm --filter @realtime-git-viewer/api build",
    "dev:mock": "pnpm --filter @realtime-git-viewer/mock dev",
    "build:mock": "pnpm --filter @realtime-git-viewer/mock build",
    "dev:web": "pnpm --filter @realtime-git-viewer/web dev",
    "build:web": "pnpm --filter @realtime-git-viewer/web build",
    "preview:web": "pnpm --filter @realtime-git-viewer/web preview",
    "capture:web": "pnpm --filter @realtime-git-viewer/web capture",
    "build:cli": "pnpm --filter refscope build",
    "dev:cli": "pnpm --filter refscope build && node apps/cli/bin/refscope.mjs --repo .",
    "dev": "pnpm dev:mock",
    "build": "pnpm build:api && pnpm build:mock && pnpm build:web",
    "test": "pnpm --filter @realtime-git-viewer/api test"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.2"
    }
  }
}
