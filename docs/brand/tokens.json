{
  "$schema": "https://tr.designtokens.org/format/",
  "$meta": {
    "version": "2025.10",
    "project": "Refscope",
    "metaphor": "Observatory",
    "generated": "2026-05-02",
    "colorModel": "OKLCH",
    "notes": "All OKLCH values expressed as 'oklch(L C H)'. Light/dark variants are separate token groups. Hue 250 = cool blue-gray neutral. Hue 200 = cyan-teal accent."
  },

  "color": {
    "$type": "color",

    "neutral": {
      "$description": "Cool gray palette. Chroma ~0.008-0.012 at hue 250 for subtle blue-gray cast. Achromatic near extremes.",
      "50":  { "$value": "oklch(0.985 0.006 250)", "$description": "Lightest surface. Not pure white — faint cool tint. Light bg." },
      "100": { "$value": "oklch(0.958 0.008 250)", "$description": "Subtle surface tint. Hover bg in light mode." },
      "200": { "$value": "oklch(0.920 0.010 250)", "$description": "Disabled surface, input bg." },
      "300": { "$value": "oklch(0.860 0.010 250)", "$description": "Decorative borders, dividers. Light mode." },
      "400": { "$value": "oklch(0.760 0.010 250)", "$description": "Placeholder text, muted icons." },
      "500": { "$value": "oklch(0.620 0.010 250)", "$description": "Mid gray. Subtle foreground." },
      "600": { "$value": "oklch(0.480 0.010 250)", "$description": "Secondary text. Both modes capable." },
      "700": { "$value": "oklch(0.360 0.010 250)", "$description": "Strong secondary text." },
      "800": { "$value": "oklch(0.250 0.008 250)", "$description": "Near-dark. Dark mode surface raised." },
      "900": { "$value": "oklch(0.165 0.008 250)", "$description": "Body text in light mode. Dark surface base." },
      "950": { "$value": "oklch(0.108 0.006 250)", "$description": "Darkest surface. Dark mode bg." }
    },

    "accent": {
      "$description": "Single cyan-teal accent. Hue 200. Used exclusively for selection, focus rings, live-update pulse. Not for decorative use.",
      "300": { "$value": "oklch(0.820 0.110 200)", "$description": "Light tint for accent backgrounds in dark mode." },
      "400": { "$value": "oklch(0.730 0.135 200)", "$description": "Accent hover in dark mode." },
      "500": { "$value": "oklch(0.630 0.155 200)", "$description": "Primary accent. Focus rings light mode, selection highlight." },
      "600": { "$value": "oklch(0.520 0.140 200)", "$description": "Accent pressed/active." },
      "700": { "$value": "oklch(0.410 0.120 200)", "$description": "Deep accent, text on light accent bg." }
    },

    "semantic": {
      "$description": "Semantic / alert colors. Max 3 simultaneous on screen; exceed → aggregate banner.",

      "warning": {
        "$description": "Amber. Rewritten history, force-push. Hue ~65.",
        "light": {
          "bg":   { "$value": "oklch(0.960 0.030 75)", "$description": "Warning surface in light mode." },
          "fg":   { "$value": "oklch(0.420 0.100 65)", "$description": "Warning text/icon. Ensures ≥4.5:1 on warning.bg." },
          "border": { "$value": "oklch(0.780 0.090 70)", "$description": "Warning border." }
        },
        "dark": {
          "bg":   { "$value": "oklch(0.260 0.050 65)", "$description": "Warning surface dark mode. Chroma reduced to avoid glare." },
          "fg":   { "$value": "oklch(0.820 0.100 70)", "$description": "Warning text dark. Ensures ≥4.5:1 on warning-dark.bg." },
          "border": { "$value": "oklch(0.480 0.090 65)", "$description": "Warning border dark." }
        }
      },

      "error": {
        "$description": "Red. Hard errors only — not for warnings. Hue ~15.",
        "light": {
          "bg":   { "$value": "oklch(0.965 0.025 15)", "$description": "Error surface light." },
          "fg":   { "$value": "oklch(0.390 0.130 20)", "$description": "Error text light. ≥4.5:1 on error.bg." },
          "border": { "$value": "oklch(0.720 0.130 20)", "$description": "Error border light." }
        },
        "dark": {
          "bg":   { "$value": "oklch(0.250 0.060 15)", "$description": "Error surface dark." },
          "fg":   { "$value": "oklch(0.800 0.110 20)", "$description": "Error text dark. ≥4.5:1 on error-dark.bg." },
          "border": { "$value": "oklch(0.460 0.110 15)", "$description": "Error border dark." }
        }
      },

      "success": {
        "$description": "Muted green. Used sparingly (signed commits, merge success). Hue ~155.",
        "light": {
          "bg":   { "$value": "oklch(0.960 0.020 155)", "$description": "Success surface light." },
          "fg":   { "$value": "oklch(0.380 0.090 155)", "$description": "Success text light. ≥4.5:1 on success.bg." },
          "border": { "$value": "oklch(0.740 0.075 155)", "$description": "Success border light." }
        },
        "dark": {
          "bg":   { "$value": "oklch(0.250 0.045 155)", "$description": "Success surface dark." },
          "fg":   { "$value": "oklch(0.800 0.085 155)", "$description": "Success text dark. ≥4.5:1 on success-dark.bg." },
          "border": { "$value": "oklch(0.460 0.070 155)", "$description": "Success border dark." }
        }
      },

      "info": {
        "$description": "Neutral info — signature unknown, general annotation. Uses cool gray, no chroma emphasis.",
        "light": {
          "bg":   { "$value": "oklch(0.955 0.008 250)", "$description": "Info surface light." },
          "fg":   { "$value": "oklch(0.380 0.010 250)", "$description": "Info text light." },
          "border": { "$value": "oklch(0.780 0.010 250)", "$description": "Info border light." }
        },
        "dark": {
          "bg":   { "$value": "oklch(0.240 0.008 250)", "$description": "Info surface dark." },
          "fg":   { "$value": "oklch(0.820 0.010 250)", "$description": "Info text dark." },
          "border": { "$value": "oklch(0.450 0.010 250)", "$description": "Info border dark." }
        }
      }
    },

    "semantic-role": {
      "$description": "Semantic roles that map neutral/accent to named intents. Light mode defaults.",

      "bg": {
        "base":    { "$value": "{color.neutral.50}",  "$description": "Primary app background. Slightly cool tinted." },
        "raised":  { "$value": "{color.neutral.100}", "$description": "Elevated panel, card." },
        "sunken":  { "$value": "{color.neutral.200}", "$description": "Input field, inset well." },
        "overlay": { "$value": "{color.neutral.50}",  "$description": "Modal/popover bg (light). Use elevation shadow to differentiate." }
      },
      "fg": {
        "base":    { "$value": "{color.neutral.900}", "$description": "Body text. ≥7:1 on bg.base." },
        "subtle":  { "$value": "{color.neutral.600}", "$description": "Secondary/helper text. ≥4.5:1." },
        "muted":   { "$value": "{color.neutral.400}", "$description": "Placeholder, disabled. Decorative only — do not use for meaningful text." },
        "onAccent": { "$value": "{color.neutral.950}", "$description": "Text/icon on accent-colored surface." }
      },
      "border": {
        "base":      { "$value": "{color.neutral.300}", "$description": "Default border. ≥3:1 decorative." },
        "subtle":    { "$value": "{color.neutral.200}", "$description": "Hairline divider." },
        "strong":    { "$value": "{color.neutral.500}", "$description": "Emphasized separator." },
        "focus":     { "$value": "{color.accent.500}",  "$description": "Focus ring. 2px solid + 2px offset. Accent only." }
      },
      "surface": {
        "selected":  { "$value": "{color.accent.500}", "$description": "Selected row/item tint at 12% opacity." },
        "hover":     { "$value": "{color.neutral.100}", "$description": "Row hover." },
        "active":    { "$value": "{color.neutral.200}", "$description": "Row pressed." }
      }
    }
  },

  "typography": {
    "$description": "Dense UI typography. Inter primary, IBM Plex Sans fallback. JetBrains Mono for code/hash/timestamp.",

    "font-family": {
      "ui": {
        "$type": "fontFamily",
        "$value": ["Inter", "IBM Plex Sans", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "system-ui", "sans-serif"],
        "$description": "Primary UI font. No ligatures."
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "IBM Plex Mono", "ui-monospace", "SFMono-Regular", "Menlo", "Monaco", "Consolas", "monospace"],
        "$description": "Monospace. Ligatures OFF. tabular-nums."
      }
    },

    "font-size": {
      "xs":      { "$type": "dimension", "$value": "12px", "$description": "Caption, badge, timestamp label." },
      "sm":      { "$type": "dimension", "$value": "13px", "$description": "Secondary text, sidebar labels." },
      "base":    { "$type": "dimension", "$value": "14px", "$description": "Body text. Primary UI size." },
      "md":      { "$type": "dimension", "$value": "15px", "$description": "Slightly emphasized body, dialog title." },
      "lg":      { "$type": "dimension", "$value": "17px", "$description": "Section header, modal title. Rare." },
      "mono-xs": { "$type": "dimension", "$value": "12px", "$description": "Hash/OID display. tabular-nums." }
    },

    "font-weight": {
      "regular": { "$type": "fontWeight", "$value": 400, "$description": "Normal weight. Default body." },
      "medium":  { "$type": "fontWeight", "$value": 500, "$description": "Emphasis. Labels, column headers." },
      "bold":    { "$type": "fontWeight", "$value": 700, "$description": "Strong emphasis. Use sparingly — max 1-2 instances per view." }
    },

    "line-height": {
      "tight":   { "$type": "number", "$value": 1.25, "$description": "Dense rows (28-32px target). Code blocks." },
      "snug":    { "$type": "number", "$value": 1.375, "$description": "UI labels, single-line." },
      "normal":  { "$type": "number", "$value": 1.5,   "$description": "Body paragraphs." }
    },

    "letter-spacing": {
      "tight":  { "$type": "dimension", "$value": "-0.01em", "$description": "Display sizes (lg). Pull text closer." },
      "normal": { "$type": "dimension", "$value": "0em",     "$description": "Default. Most UI text." },
      "wide":   { "$type": "dimension", "$value": "0.04em",  "$description": "Uppercase labels, badge text." }
    }
  },

  "spacing": {
    "$type": "dimension",
    "$description": "4px base grid. Steps: 4/8/12/16/24/32. Values 5, 7, 11 are explicitly forbidden.",
    "0":  { "$value": "0px",  "$description": "No spacing." },
    "1":  { "$value": "4px",  "$description": "Base unit. Tight inline padding." },
    "2":  { "$value": "8px",  "$description": "Component internal padding." },
    "3":  { "$value": "12px", "$description": "Row vertical padding, small gap." },
    "4":  { "$value": "16px", "$description": "Standard section padding." },
    "6":  { "$value": "24px", "$description": "Panel padding, group gap." },
    "8":  { "$value": "32px", "$description": "Large section gap." },
    "row-height-min": { "$value": "28px", "$description": "Dense row minimum height." },
    "row-height-max": { "$value": "32px", "$description": "Dense row maximum height." }
  },

  "border-radius": {
    "$type": "dimension",
    "$description": "Sharp-biased radii. 8px+ is forbidden. Default is 4px.",
    "none":  { "$value": "0px", "$description": "No radius. Tags, inline code chips." },
    "xs":    { "$value": "2px", "$description": "Minimal rounding. Checkboxes, small badges." },
    "sm":    { "$value": "4px", "$description": "Default radius. Buttons, inputs, cards." },
    "md":    { "$value": "6px", "$description": "Slightly softer. Popovers, dropdowns." }
  },

  "elevation": {
    "$type": "shadow",
    "$description": "3-level elevation system. Minimal. No heavy drop shadows.",
    "none":    { "$value": "none", "$description": "Flat surfaces. Most UI elements." },
    "subtle": {
      "$value": "0 1px 2px oklch(0.108 0.006 250 / 0.08), 0 0 0 1px oklch(0.860 0.010 250 / 0.6)",
      "$description": "Cards, raised panels. Light mode only. Dark: replace with border."
    },
    "overlay": {
      "$value": "0 4px 16px oklch(0.108 0.006 250 / 0.16), 0 1px 4px oklch(0.108 0.006 250 / 0.10), 0 0 0 1px oklch(0.860 0.010 250 / 0.5)",
      "$description": "Modals, popovers, command palette."
    },
    "subtle-dark": {
      "$value": "0 1px 2px oklch(0 0 0 / 0.30), 0 0 0 1px oklch(0.250 0.008 250 / 0.8)",
      "$description": "Cards raised in dark mode."
    },
    "overlay-dark": {
      "$value": "0 4px 16px oklch(0 0 0 / 0.50), 0 1px 4px oklch(0 0 0 / 0.30), 0 0 0 1px oklch(0.250 0.008 250 / 0.9)",
      "$description": "Modals, popovers in dark mode."
    }
  },

  "motion": {
    "$description": "Animation timing. All easing uses CSS cubic-bezier. Prefer reduced-motion via prefers-reduced-motion.",

    "duration": {
      "instant":  { "$type": "duration", "$value": "0ms",   "$description": "No transition. State that must be immediate." },
      "fast":     { "$type": "duration", "$value": "120ms",  "$description": "Micro-interactions: hover bg, checkbox toggle, icon swap." },
      "normal":   { "$type": "duration", "$value": "180ms",  "$description": "Panel open/close, dropdown, row selection." },
      "moderate": { "$type": "duration", "$value": "240ms",  "$description": "Sidebar expand, dialog appear." },
      "slow":     { "$type": "duration", "$value": "300ms",  "$description": "Full-page transitions, SSE pulse fade." }
    },

    "easing": {
      "standard":    { "$type": "cubicBezier", "$value": [0.2, 0.0, 0.0, 1.0], "$description": "Default. Enter/exit UI elements." },
      "decelerate":  { "$type": "cubicBezier", "$value": [0.0, 0.0, 0.2, 1.0], "$description": "Elements entering screen." },
      "accelerate":  { "$type": "cubicBezier", "$value": [0.4, 0.0, 1.0, 1.0], "$description": "Elements leaving screen." },
      "spring":      { "$type": "cubicBezier", "$value": [0.34, 1.56, 0.64, 1.0], "$description": "Playful spring. Reserved for accent pulse only." }
    }
  },

  "z-index": {
    "$type": "number",
    "$description": "Z-index scale. Predictable layering.",
    "base":     { "$value": 0,    "$description": "Normal document flow." },
    "raised":   { "$value": 10,   "$description": "Sticky headers, row hover affordances." },
    "dropdown": { "$value": 100,  "$description": "Dropdowns, context menus." },
    "sticky":   { "$value": 200,  "$description": "Sticky bars, persistent top bar." },
    "overlay":  { "$value": 300,  "$description": "Modal backdrop." },
    "modal":    { "$value": 400,  "$description": "Modal content." },
    "toast":    { "$value": 500,  "$description": "Notifications, toasts." },
    "tooltip":  { "$value": 600,  "$description": "Tooltips — always on top." }
  }
}
